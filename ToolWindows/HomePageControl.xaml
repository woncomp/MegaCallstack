<UserControl x:Class="MegaCallstack.ToolWindows.HomePageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:local="clr-namespace:MegaCallstack.ToolWindows"
              mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ArrowTailGeometryConverter x:Key="ArrowTailGeometryConverter"/>
        <local:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>

        <Style x:Key="HomePageButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MaxWidth" Value="400"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ActionButtonBackgroundActiveBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ActionButtonBackgroundBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomePageText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
        <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0">
            <!-- Curved arrow: occupies the space to the left of the title text.
                 The center column matches the title text width, so the arrow tail
                 ends at the horizontal position where the title text begins.
                 Arrowhead at top-left of the left cell. -->
            <Grid Height="108">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="{Binding ActualWidth, ElementName=TitleText, Converter={StaticResource DoubleToGridLengthConverter}}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Arrow container: the tail stretches to its size while the arrowhead stays fixed. -->
                <Grid x:Name="ArrowContainer" Grid.Column="0">
                    <!-- Tail curve: generated in absolute coordinates based on container size. -->
                    <Path Stroke="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                          StrokeThickness="6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round">
                        <Path.Data>
                            <MultiBinding Converter="{StaticResource ArrowTailGeometryConverter}">
                                <Binding Path="ActualWidth" ElementName="ArrowContainer"/>
                                <Binding Path="ActualHeight" ElementName="ArrowContainer"/>
                            </MultiBinding>
                        </Path.Data>
                    </Path>
                    <!-- Arrowhead: fixed size, does not stretch with the window.
                         Positioned so its base center meets the tail end. -->
                    <Path Stretch="None"
                          Width="20" Height="16"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Margin="7,-1,0,0"
                          Fill="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                          Data="M 0 16 L 10 0 L 20 16 Z"/>
                </Grid>
            </Grid>

            <TextBlock x:Name="TitleText" Text="Click to capture a callstack" Style="{StaticResource HomePageText}" FontSize="15" FontWeight="SemiBold" Margin="0,-2,0,6"/>

            <TextBlock Text="or" Style="{StaticResource HomePageText}" FontSize="13" Opacity="0.7"/>

            <!-- Resume section: instruction text above the session-name button -->
            <TextBlock Text="Resume the previous session" Style="{StaticResource HomePageText}" FontSize="13"
                       Visibility="{Binding CanResumePreviousSession, Converter={StaticResource BoolToVis}}"/>
            <Button Style="{StaticResource HomePageButton}"
                    Command="{Binding ActivateSessionCommand}"
                    CommandParameter="{Binding PreviousSession}"
                    IsEnabled="{Binding CanResumePreviousSession}"
                    Content="{Binding PreviousSessionName}"
                    Visibility="{Binding CanResumePreviousSession, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Text="or" Style="{StaticResource HomePageText}" FontSize="13" Opacity="0.7"/>

            <Button Style="{StaticResource HomePageButton}"
                    Command="{Binding SwitchToSessionViewCommand}"
                    IsEnabled="{Binding HasAnySessions}"
                    Content="Browse session history"/>
        </StackPanel>
    </Grid>
</UserControl>
