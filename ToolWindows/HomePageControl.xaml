<UserControl x:Class="MegaCallstack.ToolWindows.HomePageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="HomePageButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MaxWidth" Value="400"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ActionButtonBackgroundActiveBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ActionButtonBackgroundBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomePageText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>

        <Style x:Key="CurvedArrowPath" TargetType="Path">
            <Setter Property="Stretch" Value="Fill"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
        <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0">
            <!-- Curved arrow: occupies left 50% of the parent width.
                 Tail at bottom-right (horizontal center of treeview area).
                 Arrowhead at top-left (aligned with the toolbar capture button).
                 No margin/padding on the arrow element itself. -->
            <Grid Height="100">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Tail curve: stretches with the column width. -->
                <Path Grid.Column="0" Style="{StaticResource CurvedArrowPath}"
                      Stroke="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                      StrokeThickness="6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 0 0 M 1 1 C 0.5 1, 0.06 0.5, 0.06 0.15"/>
                <!-- Arrowhead: fixed size, does not stretch with the window.
                     Positioned so its base center meets the tail end. -->
                <Path Grid.Column="0"
                      Stretch="None"
                      Width="20" Height="16"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="2,-1,0,0"
                      Fill="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                      Data="M 0 16 L 10 0 L 20 16 Z"/>
            </Grid>

            <TextBlock Text="Click to capture a callstack" Style="{StaticResource HomePageText}" FontSize="15" FontWeight="SemiBold"/>

            <TextBlock Text="or" Style="{StaticResource HomePageText}" FontSize="13" Opacity="0.7"/>

            <!-- Resume section: instruction text above the session-name button -->
            <TextBlock Text="Resume the previous session" Style="{StaticResource HomePageText}" FontSize="13"
                       Visibility="{Binding CanResumePreviousSession, Converter={StaticResource BoolToVis}}"/>
            <Button Style="{StaticResource HomePageButton}"
                    Command="{Binding ActivateSessionCommand}"
                    CommandParameter="{Binding PreviousSession}"
                    IsEnabled="{Binding CanResumePreviousSession}"
                    Content="{Binding PreviousSessionName}"
                    Visibility="{Binding CanResumePreviousSession, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Text="or" Style="{StaticResource HomePageText}" FontSize="13" Opacity="0.7"/>

            <Button Style="{StaticResource HomePageButton}"
                    Command="{Binding SwitchToSessionViewCommand}"
                    IsEnabled="{Binding HasAnySessions}"
                    Content="Browse session history"/>
        </StackPanel>
    </Grid>
</UserControl>
