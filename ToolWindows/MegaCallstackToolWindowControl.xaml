<UserControl x:Class="MegaCallstack.ToolWindows.MegaCallstackToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MegaCallstack.ToolWindows"
             xmlns:controls="clr-namespace:MegaCallstack.Controls"
             xmlns:models="clr-namespace:MegaCallstack.Models"
              xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:vsimg="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
              xmlns:vscat="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
              xmlns:vsplat="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Imaging"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Theme-aware resource keys. We reference the VS EnvironmentColors
             BrushKeys directly via DynamicResource so the brushes (and the
             CrispImage icon theming that reads them) follow the active color
             theme. The previous code wrapped *ColorKey resources in
             SolidColorBrushes and used ThemedDialogColors, which did not
             resolve correctly inside a tool window. -->
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <local:BoolToBoldConverter x:Key="BoldConverter"/>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ActionButtonBackgroundActiveBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ActionButtonBackgroundBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HomePageButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="180"/>
        </Style>

        <Style x:Key="HomePageText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>

        <Style x:Key="CurvedArrowPath" TargetType="Path">
            <Setter Property="Stroke" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Setter Property="StrokeThickness" Value="6"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="Stretch" Value="Fill"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
        </Style>

        <Style x:Key="TreeViewItemStyle" TargetType="controls:CallstackTreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="FontWeight" Value="{Binding IsBold, Converter={StaticResource BoldConverter}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="Jump to caller position"
                                  Command="{Binding PlacementTarget.Tag.JumpToCallerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Jump to stack frame position"
                                  Command="{Binding PlacementTarget.Tag.JumpToFrameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="Set Color">
                            <MenuItem Header="Red" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FFE74856"/>
                            <MenuItem Header="Green" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FF3DC46D"/>
                            <MenuItem Header="Blue" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FF3B99E4"/>
                            <MenuItem Header="Orange" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FFD69E3E"/>
                            <MenuItem Header="Purple" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FFB062D1"/>
                        </MenuItem>
                        <MenuItem Header="Clear Color" Command="{Binding PlacementTarget.Tag.ClearColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="{Binding PlacementTarget.Tag.AncestorsMenuHeader, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  Command="{Binding PlacementTarget.Tag.ToggleAncestorsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel HorizontalAlignment="Stretch">
                            <!-- Bd carries a SOLID themed background as the base
                                 layer. CrispImage icons theme themselves by reading
                                 the nearest solid ancestor background, so the base
                                 must always be a real (non-transparent) brush. The
                                 node's highlight color, selection, and hover states
                                 are drawn on the ColorLayer overlay on top, so they
                                 never leave the icons on a null/transparent
                                 background (which would break icon theming). -->
                            <Border x:Name="Bd"
                                    Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                                    BorderThickness="0"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalAlignment="Stretch">
                                <Grid>
                                    <!-- User-set highlight color (null/transparent
                                         for uncolored nodes, letting Bd show through). -->
                                    <Border x:Name="ColorLayer" Background="{Binding DisplayBackground}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon column: toggle for parents, code icon for leaves.
                                             No Background is set here on purpose; a transparent
                                             brush would interfere with CrispImage theming. -->
                                        <Grid Grid.Column="0" Width="16" Height="16">
                                            <ToggleButton x:Name="Expander"
                                                          ClickMode="Press"
                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                          Visibility="Collapsed">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Grid Width="16" Height="16">
                                                            <vsimg:CrispImage x:Name="CollapsedIcon"
                                                                              Moniker="{x:Static vscat:KnownMonikers.ExpandRight}"
                                                                              Width="16" Height="16"/>
                                                            <vsimg:CrispImage x:Name="ExpandedIcon"
                                                                              Moniker="{x:Static vscat:KnownMonikers.ExpandDown}"
                                                                              Width="16" Height="16"
                                                                              Visibility="Collapsed"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="CollapsedIcon" Property="Visibility" Value="Collapsed"/>
                                                                <Setter TargetName="ExpandedIcon" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <vsimg:CrispImage x:Name="LeafIcon"
                                                              Moniker="{x:Static vscat:KnownMonikers.ThisLine}"
                                                              Width="16" Height="16"/>
                                        </Grid>

                                        <ContentPresenter x:Name="PART_Header"
                                                          Grid.Column="1"
                                                          Margin="2,0,0,0"
                                                          ContentSource="Header"
                                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="16,0,0,0"
                                            Visibility="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <!-- Hover off Bd.IsMouseOver, NOT the TreeViewItem's
                                 IsMouseOver. The item's IsMouseOver is True for the
                                 item OR any descendant, so it would cascade up and
                                 highlight every ancestor. Bd only wraps this item's
                                 own header row (not the ItemsHost/children), so its
                                 IsMouseOver is True only when the mouse is directly
                                 over this row. Selection is evaluated after hover so
                                 a selected item keeps its selection color on hover. -->
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="ColorLayer" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ListItemMouseOverBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ColorLayer" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.SelectedItemActiveBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Expander" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="LeafIcon" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SessionListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.SelectedItemActiveBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ListItemMouseOverBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Set ImageThemingUtilities.ImageBackgroundColor on the root so every
         CrispImage descendant (toolbar buttons, tree expand/collapse/leaf
         icons) knows the background color it is rendered on. CrispImage uses
         this to decide whether to invert/recolor its moniker; without it the
         auto-detection that walks the visual tree can fail (notably in the
         Blue theme), producing mis-colored icons. -->
    <Grid Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
          vsplat:ImageThemingUtilities.ImageBackgroundColor="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundColorKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                BorderThickness="0,0,0,1">
            <Grid>
                <!-- Tree View toolbar -->
                <Grid x:Name="TreeViewToolbar" Margin="2,1" Visibility="{Binding IsTreeViewMode, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ToolbarButton}" Command="{Binding CaptureCommand}"
                            ToolTip="{Binding CaptureButtonTooltip}" ToolTipService.ShowOnDisabled="True" ToolTipService.InitialShowDelay="0" Padding="4,2">
                        <vsimg:CrispImage Moniker="{x:Static vscat:KnownMonikers.CaptureFrame}" />
                    </Button>
                    <TextBox x:Name="SearchBox" Grid.Column="1" Style="{StaticResource SearchTextBox}"
                             Margin="2,0" VerticalAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="SearchBox_GotFocus"/>
                    <Button Grid.Column="2" Style="{StaticResource ToolbarButton}" Command="{Binding PrevMatchCommand}"
                            ToolTip="Previous Match" Padding="4,2">
                        <vsimg:CrispImage Moniker="{x:Static vscat:KnownMonikers.MoveUp}" />
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource ToolbarButton}" Command="{Binding NextMatchCommand}"
                            ToolTip="Next Match" Padding="4,2">
                        <vsimg:CrispImage Moniker="{x:Static vscat:KnownMonikers.MoveDown}" />
                    </Button>
                </Grid>

                <!-- Session View toolbar -->
                <Grid x:Name="SessionViewToolbar" Margin="2,1" Visibility="{Binding IsSessionViewMode, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ToolbarButton}" Command="{Binding CreateSessionCommand}"
                            Padding="4,2" Content="New Session"/>
                    <TextBox x:Name="SessionFilterBox" Grid.Column="1" Style="{StaticResource SearchTextBox}"
                             Margin="2,0" VerticalAlignment="Center"
                             Text="{Binding SessionFilterText, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="SearchBox_GotFocus"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Middle content -->
        <Grid Grid.Row="1">
            <!-- Tree View content -->
            <controls:CallstackTreeView x:Name="MainTreeView"
                      Background="Transparent"
                      BorderThickness="0"
                      ItemsSource="{Binding DisplayTreeNodes}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Visibility="{Binding IsTreeViewContentVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                      TreeViewItem.Selected="TreeView_Selected"
                      TreeViewItem.PreviewMouseRightButtonDown="TreeViewItem_PreviewMouseRightButtonDown"
                      TreeViewItem.Collapsed="TreeViewItem_ExpandedCollapsed"
                      TreeViewItem.Expanded="TreeViewItem_ExpandedCollapsed"
                      controls:CallstackTreeViewItem.ItemDoubleClick="TreeViewItem_DoubleClick"
                      ItemContainerStyle="{StaticResource TreeViewItemStyle}">
                <controls:CallstackTreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type models:TreeViewNode}" ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" ToolTip="{Binding TooltipText}">
                            <controls:HighlightTextBlock Text="{Binding DisplayText}"
                                                         HighlightText="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         HighlightBackground="#FFFFFF00"
                                                         Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </controls:CallstackTreeView.ItemTemplate>
            </controls:CallstackTreeView>

            <!-- Home page shown when no active session is available -->
            <Grid Visibility="{Binding IsHomePageVisible, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                    <!-- Curved arrow: occupies left 50% of the parent width.
                         Tail at bottom-right (horizontal center of treeview area).
                         Arrowhead at top-left (aligned with the toolbar capture button).
                         No margin/padding on the arrow element itself. -->
                    <Grid Height="100">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Style="{StaticResource CurvedArrowPath}"
                              Data="M 0.95 0.95 Q 0.3 0.45 0.15 0.2 L 0.18 0.08 M 0.07 0.14 L 0.15 0.2 L 0.24 0.16"/>
                    </Grid>

                    <TextBlock Text="Click to capture a callstack" Style="{StaticResource HomePageText}" FontSize="15" FontWeight="SemiBold"/>

                    <TextBlock Text="or" Style="{StaticResource HomePageText}" FontSize="13" Opacity="0.7"/>

                    <!-- Resume section: instruction text above the session-name button -->
                    <TextBlock Text="Resume the previous session" Style="{StaticResource HomePageText}" FontSize="13"
                               Visibility="{Binding CanResumePreviousSession, Converter={StaticResource BoolToVis}}"/>
                    <Button Style="{StaticResource HomePageButton}"
                            Command="{Binding ActivateSessionCommand}"
                            CommandParameter="{Binding PreviousSession}"
                            IsEnabled="{Binding CanResumePreviousSession}"
                            Content="{Binding PreviousSessionName}"
                            Visibility="{Binding CanResumePreviousSession, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Text="or" Style="{StaticResource HomePageText}" FontSize="13" Opacity="0.7"/>

                    <Button Style="{StaticResource HomePageButton}"
                            Command="{Binding SwitchToSessionViewCommand}"
                            IsEnabled="{Binding HasAnySessions}"
                            Content="Browse session history"/>
                </StackPanel>
            </Grid>

            <!-- Session View content -->
            <Grid Visibility="{Binding IsSessionViewMode, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="SessionViewContent"
                         Grid.Column="0"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding FilteredSessions}"
                         SelectedItem="{Binding SelectedSession}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource SessionListBoxItemStyle}"
                         MouseDoubleClick="SessionViewContent_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                                           FontSize="14"/>
                                <TextBlock Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                                           Opacity="0.6" FontSize="11"
                                           Text="{Binding CreatedTime, StringFormat='Created: {0:yyyy-MM-dd HH:mm}'}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Delete button panel -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="4,0,0,0"
                            Visibility="{Binding SelectedSession, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                    <Button Style="{StaticResource ToolbarButton}" Padding="4,2"
                            Click="DeleteSelectedSession_Click"
                            ToolTip="Delete selected session">
                        <vsimg:CrispImage Moniker="{x:Static vscat:KnownMonikers.Cancel}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                BorderThickness="0,1,0,0">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: session name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Session: "
                               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveSessionName}"
                               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Sessions" Style="{StaticResource ToolbarButton}"
                            Command="{Binding SwitchToSessionViewCommand}"
                            Visibility="{Binding IsTreeViewMode, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                    <Button Content="Trees" Style="{StaticResource ToolbarButton}"
                            Command="{Binding SwitchToTreeViewCommand}"
                            Visibility="{Binding IsSessionViewMode, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
