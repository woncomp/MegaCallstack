<UserControl x:Class="MegaCallstack.ToolWindows.MegaCallstackToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MegaCallstack.ToolWindows"
             xmlns:controls="clr-namespace:MegaCallstack.Controls"
             xmlns:models="clr-namespace:MegaCallstack.Models"
              xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:vsimg="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
              xmlns:vscat="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="ToolWindowBackgroundBrush" Color="{DynamicResource {x:Static vsui:ThemedDialogColors.WindowPanelColorKey}}"/>
        <SolidColorBrush x:Key="ToolWindowForegroundBrush" Color="{DynamicResource {x:Static vsui:ThemedDialogColors.WindowPanelTextColorKey}}"/>
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{DynamicResource {x:Static vsui:ThemedDialogColors.ListBoxColorKey}}"/>
        <SolidColorBrush x:Key="ControlForegroundBrush" Color="{DynamicResource {x:Static vsui:ThemedDialogColors.WindowPanelTextColorKey}}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource {x:Static vsui:ThemedDialogColors.GridLineColorKey}}"/>

        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <local:BoolToBoldConverter x:Key="BoldConverter"/>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ActionButtonBackgroundActiveBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ActionButtonBackgroundBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CaretBrush" Value="{StaticResource ControlForegroundBrush}"/>
        </Style>

        <Style x:Key="TreeViewItemStyle" TargetType="controls:CallstackTreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="FontWeight" Value="{Binding IsBold, Converter={StaticResource BoldConverter}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="Jump to caller position"
                                  Command="{Binding PlacementTarget.Tag.JumpToCallerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Jump to stack frame position"
                                  Command="{Binding PlacementTarget.Tag.JumpToFrameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="Set Color">
                            <MenuItem Header="Red" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FFE74856"/>
                            <MenuItem Header="Green" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FF3DC46D"/>
                            <MenuItem Header="Blue" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FF3B99E4"/>
                            <MenuItem Header="Orange" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FFD69E3E"/>
                            <MenuItem Header="Purple" Command="{Binding PlacementTarget.Tag.SetColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="#FFB062D1"/>
                        </MenuItem>
                        <MenuItem Header="Clear Color" Command="{Binding PlacementTarget.Tag.ClearColorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd"
                                    Background="{Binding DisplayBackground}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1,0,0,0"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Visibility="{Binding HasItems, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="16">
                                                    <TextBlock x:Name="Arrow" Text="&#x25B6;" FontFamily="Segoe UI"
                                                               FontSize="8" Foreground="{StaticResource ControlForegroundBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               RenderTransformOrigin="0.5,0.5">
                                                        <TextBlock.RenderTransform>
                                                            <RotateTransform Angle="0"/>
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="16,0,0,0"
                                            Visibility="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.SelectedItemActiveBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ListItemMouseOverBrushKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SessionListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.SelectedItemActiveBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static vsui:ThemedDialogColors.ListItemMouseOverBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ToolWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="{StaticResource ControlBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <!-- Tree View toolbar -->
                <Grid x:Name="TreeViewToolbar" Margin="2,1" Visibility="{Binding IsTreeViewMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ToolbarButton}" Command="{Binding CaptureCommand}"
                            ToolTip="Capture Callstack" Padding="4,2">
                        <vsimg:CrispImage Moniker="{x:Static vscat:KnownMonikers.CaptureFrame}" />
                    </Button>
                    <TextBox x:Name="SearchBox" Grid.Column="1" Style="{StaticResource SearchTextBox}"
                             Margin="2,0" VerticalAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="SearchBox_GotFocus"/>
                    <Button Grid.Column="2" Style="{StaticResource ToolbarButton}" Command="{Binding PrevMatchCommand}"
                            ToolTip="Previous Match" Padding="4,2">
                        <vsimg:CrispImage Moniker="{x:Static vscat:KnownMonikers.MoveUp}" />
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource ToolbarButton}" Command="{Binding NextMatchCommand}"
                            ToolTip="Next Match" Padding="4,2">
                        <vsimg:CrispImage Moniker="{x:Static vscat:KnownMonikers.MoveDown}" />
                    </Button>
                </Grid>

                <!-- Session View toolbar -->
                <Grid x:Name="SessionViewToolbar" Margin="2,1" Visibility="{Binding IsSessionViewMode, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ToolbarButton}" Command="{Binding CreateSessionCommand}"
                            Padding="4,2" Content="New Session"/>
                    <TextBox x:Name="SessionFilterBox" Grid.Column="1" Style="{StaticResource SearchTextBox}"
                             Margin="2,0" VerticalAlignment="Center"
                             Text="{Binding SessionFilterText, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="SearchBox_GotFocus"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Middle content -->
        <Grid Grid.Row="1">
            <!-- Tree View content -->
            <ScrollViewer x:Name="TreeViewContent"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsTreeViewMode, Converter={StaticResource BoolToVis}}">
                <controls:CallstackTreeView x:Name="MainTreeView"
                          Background="Transparent"
                          BorderThickness="0"
                          TreeViewItem.Selected="TreeView_Selected"
                          TreeViewItem.Collapsed="TreeViewItem_ExpandedCollapsed"
                          TreeViewItem.Expanded="TreeViewItem_ExpandedCollapsed"
                          controls:CallstackTreeViewItem.ItemDoubleClick="TreeViewItem_DoubleClick"
                          ItemContainerStyle="{StaticResource TreeViewItemStyle}">
                    <controls:CallstackTreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type models:TreeViewNode}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" ToolTip="{Binding TooltipText}">
                                <controls:HighlightTextBlock Text="{Binding DisplayText}"
                                                             HighlightText="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                             HighlightBackground="#FFFFFF00"
                                                             Foreground="{StaticResource ControlForegroundBrush}"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </controls:CallstackTreeView.ItemTemplate>
                </controls:CallstackTreeView>
            </ScrollViewer>

            <!-- Session View content -->
            <Grid Visibility="{Binding IsSessionViewMode, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ListBox x:Name="SessionViewContent"
                         Grid.Column="0"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding FilteredSessions}"
                         SelectedItem="{Binding SelectedSession}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource SessionListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource ControlForegroundBrush}"
                                           FontSize="14"/>
                                <TextBlock Foreground="{StaticResource ControlForegroundBrush}"
                                           Opacity="0.6" FontSize="11"
                                           Text="{Binding CreatedTime, StringFormat='Created: {0:yyyy-MM-dd HH:mm}'}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ActivateSessionCommand}"
                                      CommandParameter="{Binding SelectedItem, ElementName=SessionViewContent}"/>
                    </ListBox.InputBindings>
                </ListBox>

                <!-- Delete button panel -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="4,0,0,0"
                            Visibility="{Binding SelectedSession, Converter={StaticResource BoolToVis}}">
                    <Button Style="{StaticResource ToolbarButton}" Padding="4,2"
                            Click="DeleteSelectedSession_Click"
                            ToolTip="Delete selected session">
                        <vsimg:CrispImage Moniker="{x:Static vscat:KnownMonikers.Cancel}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Bottom status bar -->
        <Border Grid.Row="2" Background="{StaticResource ControlBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: session name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Session: " Foreground="{StaticResource ControlForegroundBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveSessionName}"
                               Foreground="{StaticResource ControlForegroundBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Sessions" Style="{StaticResource ToolbarButton}"
                            Command="{Binding SwitchToSessionViewCommand}"
                            Visibility="{Binding IsTreeViewMode, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Trees" Style="{StaticResource ToolbarButton}"
                            Command="{Binding SwitchToTreeViewCommand}"
                            Visibility="{Binding IsSessionViewMode, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
